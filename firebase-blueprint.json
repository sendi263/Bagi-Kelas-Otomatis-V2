{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "Student records containing academic grades and personal information",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the student"
        },
        "nisn": {
          "type": "string",
          "description": "Encrypted or plain NISN identifier"
        },
        "nik": {
          "type": "string",
          "description": "Encrypted or plain NIK/NIPD identifier"
        },
        "nikSiswa": {
          "type": "string",
          "description": "Encrypted or plain Student NIK"
        },
        "religion": {
          "type": "string",
          "description": "Religion of the student"
        },
        "name": {
          "type": "string",
          "description": "Full name of the student"
        },
        "gender": {
          "type": "string",
          "enum": ["L", "P"],
          "description": "Gender L (Male) or P (Female)"
        },
        "birthPlace": {
          "type": "string",
          "description": "Birth place city"
        },
        "birthDate": {
          "type": "string",
          "description": "Birth date YYYY-MM-DD"
        },
        "averageGrade": {
          "type": "number",
          "description": "Average academic grade"
        },
        "asalKelas": {
          "type": "string",
          "description": "School of origin or former class"
        },
        "currentClass": {
          "type": "string",
          "description": "Current class rombel assignment"
        },
        "email": {
          "type": "string",
          "description": "Email address of student"
        },
        "address": {
          "type": "string",
          "description": "Home address"
        },
        "guardianName": {
          "type": "string",
          "description": "Name of guardian"
        },
        "status": {
          "type": "string",
          "enum": ["Aktif", "Lulus", "Mutasi", "Non-Aktif"],
          "description": "Enrollment status"
        },
        "lastUpdated": {
          "type": "string",
          "description": "Last updated date ISO string"
        }
      },
      "required": ["id", "name", "gender", "status", "lastUpdated"]
    },
    "DapodikSyncLog": {
      "title": "DapodikSyncLog",
      "description": "Logs of synchronizations with the Dapodik system",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["Inbound", "Outbound"]
        },
        "status": {
          "type": "string",
          "enum": ["Sukses", "Gagal", "Proses"]
        },
        "recordsCount": {
          "type": "number"
        },
        "operator": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      },
      "required": ["id", "timestamp", "type", "status", "operator"]
    },
    "UpdateNotification": {
      "title": "UpdateNotification",
      "description": "System and data validation alerts for operators",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["info", "warning", "success"]
        },
        "completed": {
          "type": "boolean"
        },
        "cycle": {
          "type": "string",
          "enum": ["Harian", "Mingguan", "Bulanan", "Semester"]
        }
      },
      "required": ["id", "title", "description", "date", "type", "completed", "cycle"]
    },
    "SchoolSettings": {
      "title": "SchoolSettings",
      "description": "Official metadata and settings representing the school entity",
      "type": "object",
      "properties": {
        "schoolName": {
          "type": "string"
        },
        "npsn": {
          "type": "string"
        },
        "akreditasi": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "province": {
          "type": "string"
        },
        "kabupaten: ": {
          "type": "string"
        },
        "kecamatan": {
          "type": "string"
        },
        "kepalaSekolah": {
          "type": "string"
        },
        "nipKepalaSekolah": {
          "type": "string"
        },
        "kurikulumName": {
          "type": "string"
        },
        "nipKurikulum": {
          "type": "string"
        },
        "tahunAjaran": {
          "type": "string"
        },
        "noSuratPrefix": {
          "type": "string"
        },
        "logoUrl": {
          "type": "string"
        },
        "useCustomKopImage": {
          "type": "boolean"
        },
        "kopImageUrl": {
          "type": "string"
        },
        "useCustomStampImage": {
          "type": "boolean"
        },
        "stampImageUrl": {
          "type": "string"
        }
      },
      "required": ["schoolName", "npsn", "akreditasi", "email"]
    }
  },
  "firestore": {
    "students": {
      "schema": "Student",
      "description": "A global collection of student documents"
    },
    "syncLogs": {
      "schema": "DapodikSyncLog",
      "description": "Logs tracking Dapodik integration runs"
    },
    "notifications": {
      "schema": "UpdateNotification",
      "description": "Activity warnings and general admin alerts"
    },
    "schoolSettings": {
      "schema": "SchoolSettings",
      "description": "Official configuration profiles for the school"
    }
  }
}
